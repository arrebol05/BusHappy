{
    "name": "bushappy",
    "version": "1.0.0",
    "description": "Ho Chi Minh City Bus Navigator - TypeScript Web Application",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "build:production": "tsc && vite build --mode production",
        "webpack:dev": "webpack serve --mode development --open",
        "webpack:build": "webpack --mode production",
        "type-check": "tsc --noEmit",
        "clean": "rimraf dist",
        "backend": "cd ../backend && python api_server.py"
    },
    "keywords": [
        "bus",
        "transit",
        "hcmc",
        "navigation",
        "typescript"
    ],
    "author": "BusHappy Team",
    "license": "MIT",
    "devDependencies": {
        "@types/leaflet": "^1.9.8",
        "@types/node": "^20.10.6",
        "@vitejs/plugin-legacy": "^7.2.1",
        "css-loader": "^6.8.1",
        "html-webpack-plugin": "^5.6.0",
        "rimraf": "^6.1.2",
        "style-loader": "^3.3.3",
        "ts-loader": "^9.5.1",
        "typescript": "^5.3.3",
        "vite": "^7.2.4",
        "vite-plugin-env-compatible": "^2.0.1",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^4.15.1"
    },
    "dependencies": {
        "leaflet": "^1.9.4"
    }
}
